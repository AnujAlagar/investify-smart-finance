            total_expenses = sum(amount for _, amount in self.expenses)

            if total_expenses > income:
                QMessageBox.warning(self, "Budget Error", "Your total expenses exceed your income!")
                return

            # Add remaining income as a category
            expenses_copy = list(self.expenses)
            expenses_copy.append(("Remaining Income", income - total_expenses))

            labels = [desc for desc, _ in expenses_copy]
            values = [amount for _, amount in expenses_copy]
            colors = plt.cm.Paired.colors[:len(labels)]

            plt.figure(figsize=(7, 5))
            plt.pie(values, labels=labels, colors=colors, autopct='%1.1f%%', startangle=140)
            plt.title("Income vs Expenses Breakdown")
            plt.show()

            # Store data in CSV file (entire list)
            with open("personal_finance.csv", "w", newline="", encoding='utf-8') as file:
                writer = csv.writer(file)
                writer.writerow(["Income", income])
                writer.writerow(["Description", "Amount"])
                for desc, amount in expenses_copy:
                    writer.writerow([desc, amount])

            QMessageBox.information(self, "Success", "Data has been saved to personal_finance.csv")

        except Exception:
            QMessageBox.warning(self, "Input Error", "Please enter a valid income and add at least one expense.")

