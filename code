    def add_stock(self):
        stock_symbol = self.stock_input.text().strip().upper()
        quantity = self.quantity_input.text().strip()

        if not stock_symbol or not quantity.isdigit():
            QMessageBox.warning(self, "Input Error", "Please enter a valid stock symbol and quantity.")
            return

        quantity = int(quantity)

        stock_price = self.get_stock_price(stock_symbol)
        if stock_price is None:
            QMessageBox.warning(self, "Error", "Failed to fetch stock price.")
            return

        stock_price *= 100  # Multiply the stock price by 100 (as in original code)

        self.stocks.append({"symbol": stock_symbol, "quantity": quantity, "price": stock_price, "purchase_price": stock_price})
        self.update_portfolio()

    def remove_stock(self):
        stock_symbol = self.stock_input.text().strip().upper()
        self.stocks = [stock for stock in self.stocks if stock["symbol"] != stock_symbol]
        self.update_portfolio()

    def update_portfolio(self):
        self.stock_table.setRowCount(0)

        total_value = 0
        for stock in self.stocks:
            quantity = stock["quantity"]
            stock_symbol = stock["symbol"]
            purchase_price = stock["purchase_price"]
            current_price = self.get_stock_price(stock_symbol)
            current_price = (current_price * 100) if current_price is not None else 0
            value = current_price * quantity if current_price is not None else 0

            row_position = self.stock_table.rowCount()
            self.stock_table.insertRow(row_position)
            self.stock_table.setItem(row_position, 0, QTableWidgetItem(stock_symbol))
            self.stock_table.setItem(row_position, 1, QTableWidgetItem(str(quantity)))
            self.stock_table.setItem(row_position, 2, QTableWidgetItem(f"₹{current_price}" if current_price else "N/A"))
            self.stock_table.setItem(row_position, 3, QTableWidgetItem(f"₹{value}" if value else "N/A"))

            # Profit/Loss arrow (local path used in original)
            profit_loss = current_price - purchase_price
            arrow_label = QLabel(self)
            # Try to use generic arrow icons if available, otherwise show text
            up_path = "up.jpeg"
            down_path = "down.jpeg"
            if profit_loss >= 0 and os.path.isfile(up_path):
                arrow_label.setPixmap(QPixmap(up_path).scaled(20, 20))
            elif profit_loss < 0 and os.path.isfile(down_path):
                arrow_label.setPixmap(QPixmap(down_path).scaled(20, 20))
            else:
                arrow_label.setText("▲" if profit_loss >= 0 else "▼")

            self.stock_table.setCellWidget(row_position, 4, arrow_label)
            total_value += value

        self.total_value_label.setText(f"Total Portfolio Value: ₹{total_value}")

    def get_stock_price(self, symbol):
        API_KEY = ALPHAVANTAGE_KEY
        url = f'https://www.alphavantage.co/query?function=GLOBAL_QUOTE&symbol={symbol}&apikey={API_KEY}'
        try:
            response = requests.get(url, timeout=8)
            data = response.json()
            return float(data['Global Quote']['05. price'])
        except Exception:
            return None

    def show_stock_graph_input(self):
        self.stock_graph_window = StockGraphWindow()
        self.stock_graph_window.show()

class StockGraphWindow(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Stock Performance Graph")
        self.setGeometry(400, 200, 1200, 650)

        self.layout = QVBoxLayout()

        self.label = QLabel("Enter Stock Symbol for Graph:", self)
        self.layout.addWidget(self.label)

        self.stock_input = QLineEdit(self)
        self.layout.addWidget(self.stock_input)

        self.graph_button = QPushButton("View Graph", self)
        self.graph_button.clicked.connect(self.show_stock_graph)
        self.layout.addWidget(self.graph_button)

        self.setLayout(self.layout)

    def show_stock_graph(self):
        stock_symbol = self.stock_input.text().strip().upper()
        if stock_symbol:
            stock_data = self.get_stock_data(stock_symbol)
            if stock_data is not None:
                self.plot_stock_data(stock_symbol, stock_data)
            else:
                QMessageBox.warning(self, "Error", "Failed to fetch stock data.")
        else:
            QMessageBox.warning(self, "Input Error", "Please enter a valid stock symbol.")

    def get_stock_data(self, symbol):
        API_KEY = ALPHAVANTAGE_KEY
        url = f'https://www.alphavantage.co/query?function=TIME_SERIES_DAILY&symbol={symbol}&apikey={API_KEY}'
        try:
            response = requests.get(url, timeout=8)
            data = response.json()
            time_series = data.get('Time Series (Daily)', {})
            dates = list(time_series.keys())[:10]
            prices = [float(time_series[date]['4. close']) * 100 for date in dates]
            return dates, prices
        except Exception:
            return None

    def plot_stock_data(self, symbol, stock_data):
        dates, prices = stock_data
        plt.figure(figsize=(10, 5))
        plt.plot(dates, prices, marker='o')
        plt.title(f"{symbol} Stock Prices Over the Last 10 Days ")
        plt.xlabel("Date")
        plt.ylabel("Price (₹)")
        plt.xticks(rotation=45)
        plt.grid()
        plt.tight_layout()
        plt.show()

