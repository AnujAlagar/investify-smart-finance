# -------------------- Helper functions --------------------
def hash_password(password: str) -> str:
    """Return SHA-256 hex digest of the password."""
    return hashlib.sha256(password.encode("utf-8")).hexdigest()

def migrate_legacy_file():
    """
    If users.csv exists and uses a 'Password' column (plain text),
    convert it to 'PasswordHash' and rewrite file with hashed passwords.
    """
    if not os.path.isfile(USERS_CSV):
        return

    # Read file and detect headers
    try:
        with open(USERS_CSV, newline='', mode='r', encoding='utf-8') as f:
            reader = csv.DictReader(f)
            fieldnames = reader.fieldnames or []
            rows = list(reader)
    except Exception:
        return

    # If already using PasswordHash, nothing to do
    if "PasswordHash" in fieldnames:
        return

    # If old 'Password' column present, convert
    if "Password" in fieldnames:
        new_rows = []
        for r in rows:
            pwd = r.get("Password", "").strip()
            pwd_hash = hash_password(pwd) if pwd else ""
            new_rows.append({
                "Email": r.get("Email", "").strip(),
                "PasswordHash": pwd_hash,
                "Name": r.get("Name", "").strip(),
                "Mobile": r.get("Mobile", "").strip()
            })
        # Rewrite file with new header
        with open(USERS_CSV, mode='w', newline='', encoding='utf-8') as f:
            writer = csv.DictWriter(f, fieldnames=['Email', 'PasswordHash', 'Name', 'Mobile'])
            writer.writeheader()
            for nr in new_rows:
                writer.writerow(nr)

def load_users():
    """
    Load users; supports both legacy (Password) and new (PasswordHash) formats.
    Returns list of dicts with Email, PasswordHash, Name, Mobile
    """
    migrate_legacy_file()

    users = []
    if not os.path.isfile(USERS_CSV):
        return users
    try:
        with open(USERS_CSV, newline='', mode='r', encoding='utf-8') as f:
            reader = csv.DictReader(f)
            for row in reader:
                users.append({
                    "Email": row.get("Email", "").strip(),
                    "PasswordHash": row.get("PasswordHash", "").strip(),
                    "Name": row.get("Name", "").strip(),
                    "Mobile": row.get("Mobile", "").strip()
                })
    except Exception:
        return []
    return users

def save_user_record(email, password_hash, name, mobile):
    file_exists = os.path.isfile(USERS_CSV)
    with open(USERS_CSV, mode='a', newline='', encoding='utf-8') as file:
        fieldnames = ['Email', 'PasswordHash', 'Name', 'Mobile']
        writer = csv.DictWriter(file, fieldnames=fieldnames)
        if not file_exists:
            writer.writeheader()
        writer.writerow({
            'Email': email,
            'PasswordHash': password_hash,
            'Name': name,
            'Mobile': mobile
        })

