class NewsWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Indian Stock Market News")
        self.setGeometry(300, 300, 600, 400)
        self.initUI()
        self.display_financial_news()

    def initUI(self):
        self.central_widget = QWidget(self)
        self.setCentralWidget(self.central_widget)
        self.layout = QVBoxLayout(self.central_widget)
        self.scroll_area = QScrollArea(self)
        self.scroll_area.setWidgetResizable(True)
        self.news_container = QWidget()
        self.news_layout = QVBoxLayout(self.news_container)
        self.scroll_area.setWidget(self.news_container)
        self.layout.addWidget(self.scroll_area)

    def get_financial_news(self):
        API_KEY = NEWS_API_KEY
        url = f'https://newsapi.org/v2/everything?q=indian%20stock%20market&language=en&sortBy=publishedAt&apiKey={API_KEY}'
        try:
            response = requests.get(url, timeout=8)
            if response.status_code == 200:
                data = response.json()
                if 'articles' in data:
                    return data['articles']
        except Exception:
            pass
        return []

    def display_financial_news(self):
        news_items = self.get_financial_news()
        if news_items:
            for item in news_items[:5]:
                news_widget = QWidget(self.news_container)
                news_layout = QVBoxLayout(news_widget)
                headline_label = QLabel(f"<b>{item.get('title','No title')}</b>", self)
                headline_label.setFont(QFont("Arial", 16))
                headline_label.setStyleSheet("color: #0056b3;")
                news_layout.addWidget(headline_label)
                snippet_label = QLabel(item.get('description', 'No summary available.'), self)
                snippet_label.setWordWrap(True)
                news_layout.addWidget(snippet_label)
                pub_time = item.get('publishedAt', 'Unknown')
                pub_time_label = QLabel(f"Published at: {self.format_time(pub_time)}", self)
                pub_time_label.setStyleSheet("font-size: 12px; color: #777777;")
                news_layout.addWidget(pub_time_label)
                self.news_layout.addWidget(news_widget)
                self.news_layout.addWidget(QLabel("<hr>"))
        else:
            no_news_label = QLabel("No financial news available at the moment.", self)
            no_news_label.setAlignment(Qt.AlignCenter)
            self.news_layout.addWidget(no_news_label)

    def format_time(self, pub_time):
        try:
            pub_time = datetime.strptime(pub_time, "%Y-%m-%dT%H:%M:%SZ")
            return pub_time.strftime("%b %d, %Y %H:%M")
        except Exception:
            return "Unknown Time"

